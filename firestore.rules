rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - photoURL: string
    //   - bio: string
    //   - role: string (required, enum: ['architect', 'buyer'])
    //
    // Collection: plans
    // Fields:
    //   - name: string (required)
    //   - description: string
    //   - walls: array (required)
    //   - createdAt: timestamp/string (required)
    //   - updatedAt: timestamp/string
    //   - authorId: string (required)
    //   - isPublic: bool (required)
    //   - price: number
    //   - marketingDescription: string
    //   - thumbnailUrl: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['architect', 'buyer'];
    }

    function isValidPlan(data) {
      return data.keys().hasAll(['name', 'authorId', 'walls', 'createdAt', 'isPublic']) &&
             data.name is string && data.name.size() < 100 &&
             data.authorId == request.auth.uid &&
             data.walls is list &&
             data.isPublic is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.role == resource.data.role;
    }

    match /plans/{planId} {
      // Anyone can read public plans, owners can read their own
      allow read: if resource.data.isPublic == true || isDocOwner();
      
      allow create: if isAuthenticated() && isValidPlan(request.resource.data);
      
      allow update: if isDocOwner() && isValidPlan(request.resource.data) &&
                      request.resource.data.authorId == resource.data.authorId;
      
      allow delete: if isDocOwner();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
